# ---- Database (PostgreSQL) ----
# Local compose: uses docker-compose.yml defaults; override here if needed.
# AWS: RDS endpoint, e.g. postgres://erms:STRONGPASS@mydb.xxxx.us-east-1.rds.amazonaws.com:5432/erms
DATABASE_URL=postgres://erms:erms@db:5432/erms

# ---- Cache (Redis) ----
# Local compose: redis://redis:6379/1
# AWS: ElastiCache primary endpoint, e.g. redis://my-cluster.xxxx.cache.amazonaws.com:6379/1
REDIS_URL=redis://redis:6379/1

# ---- Django ----
SECRET_KEY=change-me-to-a-strong-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- CORS ----
# Comma-separated frontend origins (no trailing slash). Include every dev port you use (5173 and 8080 match Vite defaults in this repo).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,http://localhost:4173,http://127.0.0.1:4173

# ---- OpenAI (AI Insights) ----
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_TOKENS=1024
AI_REQUEST_TIMEOUT_MS=30000
# Per-minute caps (DRF throttling). GET /ai/insights/ uses AI_INSIGHTS_READ_PER_MIN; OpenAI calls use AI_RATE_LIMIT_PER_MIN.
AI_RATE_LIMIT_PER_MIN=30
AI_INSIGHTS_READ_PER_MIN=300
