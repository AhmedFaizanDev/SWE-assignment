# ---------- Database ----------
POSTGRES_DB=erms
POSTGRES_USER=erms
POSTGRES_PASSWORD=replace-with-very-strong-password

# ---------- Redis ----------
REDIS_PASSWORD=replace-with-very-strong-password

# ---------- Django API ----------
SECRET_KEY=replace-with-50-plus-char-random-secret
ALLOWED_HOSTS=api.example.com,frontend.example.com
CORS_ALLOWED_ORIGINS=https://frontend.example.com
CSRF_TRUSTED_ORIGINS=https://api.example.com,https://frontend.example.com
SECURE_SSL_REDIRECT=True
RUN_MIGRATIONS=1
RUN_RAG_REINDEX=1
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# ---------- OpenAI (AI Insights) ----------
OPENAI_API_KEY=sk-your-production-api-key
OPENAI_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_TOKENS=1024
AI_REQUEST_TIMEOUT_MS=30000
AI_RATE_LIMIT_PER_MIN=30
AI_INSIGHTS_READ_PER_MIN=300

# ---------- Frontend build ----------
VITE_API_URL=https://api.example.com
